@import "./styles/weui.wxss";

page {
  background: #f5f7fa;
  color: #1f2329;
  font-size: 28rpx;
}

.app-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
}

.page-header {
  padding: 12rpx 0 24rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #111827;
}

.page-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7a7f87;
  line-height: 1.6;
}

.section-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(15, 23, 42, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.section-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7a7f87;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.metric-card {
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f7faf7;
}

.metric-label {
  font-size: 22rpx;
  color: #6b7280;
}

.metric-value {
  display: block;
  margin-top: 8rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: #111827;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #eef2f6;
  color: #4b5563;
  font-size: 24rpx;
  line-height: 56rpx;
}

.chip--active {
  background: rgba(7, 193, 96, 0.14);
  color: #058046;
}

.chip--high {
  background: #feecec;
  color: #d93026;
}

.chip--medium {
  background: #fff3db;
  color: #b26a00;
}

.chip--low {
  background: #e8f6ed;
  color: #14804a;
}

.chip--todo {
  background: #ebf5ff;
  color: #1d4ed8;
}

.chip--done {
  background: #e8f6ed;
  color: #14804a;
}

.chip--expired {
  background: #f2f4f7;
  color: #7a7f87;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.empty-card {
  padding: 48rpx 28rpx;
  text-align: center;
  color: #7a7f87;
  font-size: 26rpx;
  line-height: 1.7;
}

.link-button {
  color: #07c160;
  font-size: 26rpx;
}

.page-actions {
  margin-top: 24rpx;
}

.primary-button {
  width: 100%;
  border-radius: 999rpx;
}

.secondary-button {
  border-radius: 999rpx;
}

.footer-safe-area {
  height: 48rpx;
}

.status-muted {
  opacity: 0.72;
}

.weui-btn + .weui-btn {
  margin-top: 16rpx;
}
