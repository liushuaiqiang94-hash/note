.color-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  min-height: 60rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #f3f5f7;
  color: #4b5563;
  font-size: 24rpx;
}

.color-chip--active {
  background: rgba(7, 193, 96, 0.14);
  color: #058046;
}

.color-chip__dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
}

.category-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #edf1f5;
}

.category-row:last-child {
  border-bottom: none;
}

.category-row__main {
  flex: 1;
  min-width: 0;
}

.category-row__title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.category-row__dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
}

.category-row__meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7a7f87;
}

.category-row__actions {
  display: flex;
  gap: 12rpx;
}
