<view class="app-page">
  <view class="page-header">
    <view class="page-title">统计</view>
    <view class="page-subtitle">只展示当前后端已经提供的概览与趋势数据，不做额外推导。</view>
  </view>

  <view class="section-card">
    <view class="section-title">概览范围</view>
    <view class="chip-row">
      <view
        wx:for="{{overviewRangeOptions}}"
        wx:key="value"
        class="chip {{currentOverviewRange === item.value ? 'chip--active' : ''}}"
        data-value="{{item.value}}"
        bindtap="changeOverviewRange"
      >
        {{item.label}}
      </view>
    </view>

    <view class="metrics-grid">
      <view class="metric-card">
        <view class="metric-label">完成数</view>
        <text class="metric-value">{{overview.completedCount}}</text>
      </view>
      <view class="metric-card">
        <view class="metric-label">总任务数</view>
        <text class="metric-value">{{overview.totalCount}}</text>
      </view>
      <view class="metric-card">
        <view class="metric-label">完成率</view>
        <text class="metric-value">{{overview.completionRateText}}</text>
      </view>
      <view class="metric-card">
        <view class="metric-label">连续完成天数</view>
        <text class="metric-value">{{overview.consecutiveCompletedDays}}</text>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">趋势</view>
    <view class="section-desc">先用高可读列表展示每日完成数量，后续再决定是否升级为图表。</view>

    <view class="chip-row">
      <view
        wx:for="{{trendRangeOptions}}"
        wx:key="value"
        class="chip {{currentTrendRange === item.value ? 'chip--active' : ''}}"
        data-value="{{item.value}}"
        bindtap="changeTrendRange"
      >
        {{item.label}}
      </view>
    </view>

    <view class="trend-list" wx:if="{{trend.length}}">
      <view class="trend-row" wx:for="{{trend}}" wx:key="date">
        <view class="trend-row__date">{{item.displayDate}}</view>
        <view class="trend-row__count">完成 {{item.count}}</view>
      </view>
    </view>

    <view class="empty-card" wx:if="{{!loading && !trend.length}}">
      当前范围内还没有完成记录。
    </view>
  </view>

  <view class="weui-loadmore" wx:if="{{loading}}">
    <view class="weui-loading"></view>
    <view class="weui-loadmore__tips">统计加载中</view>
  </view>
</view>
