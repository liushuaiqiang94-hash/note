.profile-card__main {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.profile-card__avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #eef2f6;
}

.profile-card__avatar--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #058046;
  background: rgba(7, 193, 96, 0.12);
}

.profile-card__content {
  flex: 1;
  min-width: 0;
}

.profile-card__name {
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
}

.profile-card__meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7a7f87;
}
